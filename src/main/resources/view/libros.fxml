<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pageturner.controller.LibroController">

    <!-- 🔹 CENTER -->
    <center>
        <VBox spacing="15" style="-fx-padding: 15;">

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="10">

                <VBox>
                    <Label text="Gestión de Libros" styleClass="view-title"/>
                    <Label text="Administra el catálogo de libros disponibles"
                           styleClass="view-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="+ Nuevo Libro"
                        onAction="#mostrarFormulario"
                        styleClass="primary-button"/>
            </HBox>

            <!-- TABLA -->
            <TableView fx:id="tablaLibros" styleClass="table-view-modern">

                <columns>
                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colTitulo" text="Título"/>
                    <TableColumn fx:id="colAutor" text="Autor"/>
                    <TableColumn fx:id="colPrecio" text="Precio"/>
                    <TableColumn fx:id="colStock" text="Stock"/>
                </columns>

            </TableView>

            <VBox spacing="15">

                <!-- FORMULARIO -->
                <VBox fx:id="formularioBox"
                      spacing="10"
                      visible="false"
                      managed="false"
                      styleClass="form-card">

                    <Label text="Nuevo Libro" styleClass="form-title"/>

                    <GridPane hgap="10" vgap="10">

                        <Label text="Título:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtTitulo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Autor:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtAutor" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="ISBN:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtISBN" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Precio:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtPrecio" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Stock:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtStock" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                    </GridPane>

                    <!-- BOTONES -->
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Cancelar"
                                onAction="#ocultarFormulario"
                                styleClass="secondary-button"/>

                        <Button text="Guardar"
                                onAction="#guardarLibro"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>

            </VBox>

            <!-- 🔹 MÉTRICAS -->
            <VBox spacing="8" alignment="CENTER" style="-fx-padding: 10;">

                <Label text="Resumen de Libro"
                       styleClass="form-title"/>

                <HBox spacing="15"
                      alignment="CENTER"
                      maxWidth="600">

                    <!-- 📦 VENTAS -->
                    <VBox styleClass="card">
                        <Label text="📦" style="-fx-font-size: 24px;"/>
                        <Label text="Vendidos"/>
                        <Label fx:id="lblVentas" text="0" styleClass="card-value"/>
                    </VBox>

                    <!-- 💰 INGRESOS -->
                    <VBox styleClass="card">
                        <Label text="💰" style="-fx-font-size: 24px;"/>
                        <Label text="Ingresos"/>
                        <Label fx:id="lblIngresos" text="S/ 0.00" styleClass="card-value"/>
                    </VBox>

                    <!-- 📚 STOCK -->
                    <VBox styleClass="card">
                        <Label text="📚" style="-fx-font-size: 24px;"/>
                        <Label text="Stock"/>
                        <Label fx:id="lblStockDetalle" text="0" styleClass="card-value"/>
                    </VBox>

                </HBox>

            </VBox>

        </VBox>
    </center>

</BorderPane>