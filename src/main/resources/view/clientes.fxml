<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pageturner.controller.ClienteController">

    <center>
        <VBox spacing="15" style="-fx-padding: 15;">

            <!-- 🔹 HEADER (MISMO QUE LIBROS) -->
            <HBox alignment="CENTER_LEFT" spacing="10">

                <VBox>
                    <Label text="Gestión de Clientes" styleClass="view-title"/>
                    <Label text="Administra los clientes registrados en el sistema"
                           styleClass="view-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="+ Nuevo Cliente"
                        onAction="#mostrarFormulario"
                        styleClass="primary-button"/>
            </HBox>

            <!-- 🔹 TABLA -->
            <TableView fx:id="tablaClientes"
                       prefHeight="320"
                       styleClass="table-view-modern">

                <columns>
                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colNombre" text="Nombre"/>
                    <TableColumn fx:id="colDni" text="DNI"/>
                    <TableColumn fx:id="colCorreo" text="Correo"/>
                    <TableColumn fx:id="colCelular" text="Celular"/>
                </columns>

            </TableView>

            <!-- 🔹 FORMULARIO -->
            <VBox fx:id="formularioBox"
                  spacing="15"
                  visible="false"
                  managed="false"
                  styleClass="form-card">

                <Label text="Registrar Cliente" styleClass="form-title"/>

                <GridPane hgap="15" vgap="15">

                    <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="DNI:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtDni" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                    <Label text="Correo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtCorreo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Celular:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtCelular" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                </GridPane>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Cancelar"
                            onAction="#ocultarFormulario"
                            styleClass="secondary-button"/>

                    <Button text="Guardar"
                            onAction="#guardarCliente"
                            styleClass="primary-button"/>
                </HBox>

            </VBox>

            <!-- 🔹 MÉTRICAS -->
            <VBox spacing="8"
                  style="-fx-padding: 10;"
                  styleClass="form-card">

                <Label text="Detalle del Cliente" styleClass="form-title"/>

                <Label fx:id="lblCompras" text="Compras realizadas: 0"/>
                <Label fx:id="lblReservas" text="Reservas activas: 0"/>

            </VBox>

        </VBox>
    </center>

</BorderPane>