<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pageturner.controller.ClienteController">

    <!-- 🔹 TÍTULO -->
    <top>
        <Label text="Gestión de Clientes"
               style="-fx-font-size: 20px; -fx-padding: 10;" />
    </top>

    <!-- 🔹 CONTENIDO -->
    <center>
        <VBox spacing="10" style="-fx-padding: 10;">

            <VBox spacing="15">

                <!-- 🔹 BOTÓN -->
                <Button text="+ Agregar Cliente"
                        onAction="#mostrarFormulario"
                        styleClass="primary-button"/>

                <!-- 🔹 FORMULARIO -->
                <VBox fx:id="formularioBox"
                      spacing="10"
                      visible="false"
                      managed="false"
                      styleClass="form-card">

                    <Label text="Nuevo Cliente" styleClass="form-title"/>

                    <GridPane hgap="10" vgap="10">

                        <!-- FILA 1 -->
                        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="DNI:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtDni" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <!-- FILA 2 -->
                        <Label text="Correo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtCorreo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Celular:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtCelular" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                    </GridPane>

                    <!-- 🔹 BOTONES -->
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Cancelar"
                                onAction="#ocultarFormulario"
                                styleClass="secondary-button"/>

                        <Button text="Guardar"
                                onAction="#guardarCliente"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>

            </VBox>

            <!-- TABLA -->
            <TableView fx:id="tablaClientes" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colDni" text="DNI" prefWidth="120"/>
                    <TableColumn fx:id="colCorreo" text="Correo" prefWidth="180"/>
                    <TableColumn fx:id="colCelular" text="Celular" prefWidth="120"/>
                </columns>
            </TableView>

            <!-- MÉTRICAS -->
            <VBox spacing="5" style="-fx-padding: 10;">
                <Label text="Cliente seleccionado:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblCompras" text="Compras: 0"/>
                <Label fx:id="lblReservas" text="Reservas: 0"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>