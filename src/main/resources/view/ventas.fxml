<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pageturner.controller.VentaController">

    <center>
        <VBox spacing="15" style="-fx-padding: 15;">

            <!-- 🔹 HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="10">

                <VBox>
                    <Label text="Gestión de Ventas" styleClass="view-title"/>
                    <Label text="Registra y consulta las ventas realizadas"
                           styleClass="view-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="+ Nueva Venta"
                        onAction="#mostrarFormulario"
                        styleClass="primary-button"/>
            </HBox>

            <!-- 🔹 TABLA -->
            <TableView fx:id="tablaVentas"
                       prefHeight="320"
                       styleClass="table-view-modern">

                <columns>
                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colCliente" text="Cliente"/>
                    <TableColumn fx:id="colLibro" text="Libro"/>
                    <TableColumn fx:id="colCantidad" text="Cantidad"/>
                    <TableColumn fx:id="colFecha" text="Fecha"/>
                    <TableColumn fx:id="colTotal" text="Total"/>
                </columns>

            </TableView>

            <!-- 🔹 FORMULARIO -->
            <VBox fx:id="formularioBox"
                  spacing="15"
                  visible="false"
                  managed="false"
                  styleClass="form-card">

                <Label text="Registrar Venta" styleClass="form-title"/>

                <GridPane hgap="15" vgap="15">

                    <!-- FILA 1 -->
                    <Label text="Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cbCliente"
                              GridPane.rowIndex="0" GridPane.columnIndex="1"
                              prefWidth="180"/>

                    <Label text="Libro:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <ComboBox fx:id="cbLibro"
                              GridPane.rowIndex="0" GridPane.columnIndex="3"
                              prefWidth="180"/>

                    <!-- FILA 2 -->
                    <Label text="Cantidad:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtCantidad"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Stock disponible:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <Label fx:id="lblStock"
                           GridPane.rowIndex="1" GridPane.columnIndex="3"
                           style="-fx-font-weight: bold; -fx-text-fill: #27AE60;"/>

                </GridPane>

                <!-- BOTONES -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Cancelar"
                            onAction="#ocultarFormulario"
                            styleClass="secondary-button"/>

                    <Button text="Guardar"
                            onAction="#registrarVenta"
                            styleClass="primary-button"/>
                </HBox>

            </VBox>

        </VBox>
    </center>

</BorderPane>