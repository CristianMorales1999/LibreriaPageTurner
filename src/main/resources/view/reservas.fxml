<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pageturner.controller.ReservaController"
      spacing="15" style="-fx-padding: 15;">

    <Label text="Gestión de Reservas"
           style="-fx-font-size: 20px;" />

    <!-- 🔹 BOTÓN -->
    <Button text="+ Registrar Reserva"
            onAction="#mostrarFormulario"
            styleClass="primary-button"/>

    <!-- 🔹 FORMULARIO -->
    <VBox fx:id="formularioBox"
          spacing="10"
          visible="false"
          managed="false"
          styleClass="form-card">

        <Label text="Registrar Reserva" styleClass="form-title"/>

        <GridPane hgap="10" vgap="10">

            <Label text="Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cbCliente"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"
                      prefWidth="180"/>

            <Label text="Libro:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <ComboBox fx:id="cbLibro"
                      GridPane.rowIndex="0" GridPane.columnIndex="3"
                      prefWidth="180"/>

        </GridPane>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancelar"
                    onAction="#ocultarFormulario"
                    styleClass="secondary-button"/>

            <Button text="Guardar"
                    onAction="#registrarReserva"
                    styleClass="primary-button"/>
        </HBox>

    </VBox>

    <!-- 🔹 TABLA -->
    <TableView fx:id="tablaReservas">

        <columns>
            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colCliente" text="Cliente"/>
            <TableColumn fx:id="colLibro" text="Libro"/>
            <TableColumn fx:id="colEstado" text="Estado"/>
            <TableColumn fx:id="colFecha" text="Fecha"/>
        </columns>

    </TableView>

    <!-- 🔹 ACCIONES -->
    <HBox spacing="10" alignment="CENTER_RIGHT">

        <Button fx:id="btnHabilitada"
                text="Habilitar"
                onAction="#marcarHabilitada"
                styleClass="primary-button"/>

        <Button fx:id="btnCompletada"
                text="Completar"
                onAction="#marcarCompletada"
                styleClass="primary-button"/>

        <Button fx:id="btnCancelar"
                text="Cancelar"
                onAction="#cancelarReserva"
                styleClass="secondary-button"/>

    </HBox>

</VBox>