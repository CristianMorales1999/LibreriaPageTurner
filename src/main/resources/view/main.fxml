<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pageturner.controller.MainController"
            stylesheets="@/css/styles.css">

    <!-- 🔹 SIDEBAR -->
    <left>
        <VBox spacing="10" styleClass="sidebar">

            <Label text="PageTurner"
                   style="-fx-text-fill: white; -fx-font-size: 18px;" />

            <Button text="Dashboard" onAction="#irDashboard" styleClass="sidebar-button"/>
            <Button text="Libros" onAction="#irLibros" styleClass="sidebar-button"/>
            <Button text="Clientes" onAction="#irClientes" styleClass="sidebar-button"/>
            <Button text="Ventas" onAction="#irVentas" styleClass="sidebar-button"/>
            <Button text="Reservas" onAction="#irReservas" styleClass="sidebar-button"/>

        </VBox>
    </left>

    <!-- 🔹 CONTENIDO DINÁMICO -->
    <center>
        <StackPane fx:id="contenedor"/>
    </center>

</BorderPane>