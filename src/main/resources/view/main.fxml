<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pageturner.controller.MainController"
            stylesheets="@/css/styles.css">

    <!-- 🔹 SIDEBAR -->
    <left>
        <VBox spacing="10" styleClass="sidebar">

            <Label text="📚 PageTurner"
                   styleClass="sidebar-title"/>

            <Button fx:id="btnDashboard"
                    text="🏠 Dashboard"
                    onAction="#irDashboard"
                    styleClass="sidebar-button"/>

            <Button fx:id="btnLibros"
                    text="📖 Libros"
                    onAction="#irLibros"
                    styleClass="sidebar-button"/>

            <Button fx:id="btnClientes"
                    text="👤 Clientes"
                    onAction="#irClientes"
                    styleClass="sidebar-button"/>

            <Button fx:id="btnVentas"
                    text="💰 Ventas"
                    onAction="#irVentas"
                    styleClass="sidebar-button"/>

            <Button fx:id="btnReservas"
                    text="📌 Reservas"
                    onAction="#irReservas"
                    styleClass="sidebar-button"/>

        </VBox>
    </left>

    <!-- 🔹 CONTENIDO DINÁMICO -->
    <center>
        <StackPane fx:id="contenedor"/>
    </center>

</BorderPane>